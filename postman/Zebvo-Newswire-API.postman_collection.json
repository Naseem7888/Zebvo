{
  "info": {
    "_postman_id": "1f2cc9ca-7f91-4e24-9f85-9dd2a6120001",
    "name": "Zebvo Passport Dashboard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/posts?q=passport&sort=recent",
          "host": ["{{baseUrl}}"],
          "path": ["api", "posts"],
          "query": [
            { "key": "q", "value": "passport" },
            { "key": "sort", "value": "recent" }
          ]
        }
      }
    },
    {
      "name": "Translate Text",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/translate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "translate"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Passport renewal is delayed\",\n  \"language\": \"hi\"\n}"
        }
      }
    },
    {
      "name": "Export CSV",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/export/csv?q=passport",
          "host": ["{{baseUrl}}"],
          "path": ["api", "export", "csv"],
          "query": [{ "key": "q", "value": "passport" }]
        }
      }
    },
    {
      "name": "Export PDF",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/export/pdf?q=passport",
          "host": ["{{baseUrl}}"],
          "path": ["api", "export", "pdf"],
          "query": [{ "key": "q", "value": "passport" }]
        }
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "http://localhost:3000" }]
}
